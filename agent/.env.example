# Private key của agent signer (KHÁC ví deploy; địa chỉ public của nó = AGENT_SIGNER trong contract)
# Production: dùng KMS/HSM, đừng để plaintext.
AGENT_PRIVATE_KEY=0x...

# Contract đã deploy + chain
CONTRACT_ADDRESS=0xYourDeployedContract
CHAIN_ID=11155111                  # 11155111=Sepolia, 1=mainnet
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

PORT=8787
MINT_WINDOW_SEC=120                # deadline pass (pay-at-lock nên ngắn)
SHOW_DEFINITION=false              # true = gợi ý nghĩa lúc t=0 (DỄ cho bot hơn)
