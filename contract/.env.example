# Ví deploy (KHÔNG commit .env thật)
PRIVATE_KEY=0x...

# RPC
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# ── Tham số constructor ──
MAX_SUPPLY=7777
# Giá phân tầng cố định TRONG contract (USDC 6dp):
#   P1 [1..777] $0.03 | P2 [778..3111] $0.15 | P3 [3112..5444] $0.25 | P4 [5445..7777] $0.35

# Chainlink ETH/USD price feed theo chain (trả ETH, contract tự quy đổi từ giá USD):
#   Ethereum mainnet : 0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419
#   Sepolia          : 0x694AA1769357215DE4FAC081bf1f309aDC325306
PRICE_FEED=0x694AA1769357215DE4FAC081bf1f309aDC325306

# Địa chỉ public của agent signing key (ví ký pass off-chain) — KHÔNG cần nạp ETH
AGENT_SIGNER=0xe61Aa0dD87807ffaD1439d086345ddd0b5d571F4

# Metadata baseURI — đã upload Filebase (NHỚ dấu / cuối)
BASE_URI=ipfs://bafybeicdxyjzpiuiyd4snbqp3v2defc7dep2w2ajjtqkycwl3h6reejb5a/

# Ví nhận royalty 5%
ROYALTY_RECEIVER=0xYourWalletAddress
